{
  "timezone": "Asia/Kolkata",
  "poll_interval_seconds": 60,
  "remote_lookback_days": 2,
  "min_file_age_seconds": 120,
  "max_files_per_cycle": 0,
  "rebuild_dates": [],
  "download": {
    "enabled": true,
    "transfers": 8,
    "checkers": 16,
    "buffer_size": "16M",
    "retries": 3,
    "low_level_retries": 10
  },
  "sources": {
    "stream": {
      "enabled": true,
      "remote_root": "veto:veto-stream-logs/veto-stream-logs",
      "local_root": "data/raw/source=stream"
    },
    "fast": {
      "enabled": true,
      "remote_root": "veto:veto-stream-logs/veto-fast-logs",
      "remote_children": ["110280"],
      "local_root": "data/raw/source=fast"
    }
  },
  "clickhouse": {
    "enabled": false,
    "url": "http://127.0.0.1:8123",
    "database": "veto_live",
    "user": "default",
    "password": "",
    "detail_table": "live_ts_detail",
    "insert_batch_rows": 50000,
    "timeout_seconds": 30
  },
  "output": {
    "detail_root": "data/detail",
    "minute_parquet": "output/live_minute_aggregate.parquet",
    "status_parquet": "output/live_status_minute.parquet",
    "health_json": "output/live_health.json",
    "metrics_prom": "output/live_metrics.prom"
  }
}
