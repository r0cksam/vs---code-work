# ETLlive local environment.
# Copy values into ETLlive\.env when a machine needs custom paths or runtime settings.

# Optional. Defaults to ETL\tools\rclone\rclone.exe when present, else rclone from PATH.
VETO_LIVE_RCLONE_EXE=

# Optional. Defaults to ETL\config\rclone.conf when present.
RCLONE_CONFIG=

# Optional. Defaults to ETLlive\config\live_config.json.
VETO_LIVE_CONFIG=

# Optional. Defaults to ETLlive\state\live_state.json.
VETO_LIVE_STATE=

# Optional. Overrides config poll_interval_seconds.
VETO_LIVE_POLL_SECONDS=

# Optional. Overrides config min_file_age_seconds.
VETO_LIVE_MIN_FILE_AGE_SECONDS=
